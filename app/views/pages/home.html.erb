<!DOCTYPE html>
<html>
  <head>
    <title>Ecosyste.ms MCP Server</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
        line-height: 1.6;
      }
      h1 {
        color: #2c3e50;
        border-bottom: 2px solid #3498db;
        padding-bottom: 10px;
      }
      .tool {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 15px;
      }
      .tool-name {
        font-weight: bold;
        color: #495057;
        font-size: 16px;
      }
      .tool-description {
        margin-top: 5px;
        color: #6c757d;
      }
      .tool-inputs {
        margin-top: 10px;
        padding: 10px;
        background: #ffffff;
        border-radius: 4px;
        border: 1px solid #e9ecef;
      }
      .tool-inputs h4 {
        margin: 0 0 8px 0;
        font-size: 14px;
        color: #495057;
      }
      .input-param {
        font-family: 'Monaco', 'Menlo', monospace;
        font-size: 12px;
        margin-bottom: 5px;
      }
      .param-name {
        font-weight: bold;
        color: #d73a49;
      }
      .param-type {
        color: #005cc5;
      }
      .param-required {
        color: #e36209;
        font-size: 11px;
      }
      .param-description {
        color: #6a737d;
        font-style: italic;
      }
      .tools-count {
        background: #e9ecef;
        padding: 10px;
        border-radius: 5px;
        margin-bottom: 20px;
      }
      .category-section {
        margin-bottom: 30px;
      }
      .category-title {
        color: #2c3e50;
        font-size: 20px;
        font-weight: bold;
        margin-bottom: 15px;
        padding-bottom: 5px;
        border-bottom: 1px solid #dee2e6;
      }
      .category-count {
        color: #6c757d;
        font-weight: normal;
        font-size: 14px;
      }
    </style>
  </head>

  <body>
    <h1>Ecosyste.ms MCP Server</h1>
    
    <div class="tools-count">
      <strong><%= @total_tools %></strong> MCP tools available for package ecosystem analysis
    </div>

    <% @tools_by_category.sort.each do |category, tools| %>
      <div class="category-section">
        <div class="category-title">
          <%= category %>
          <span class="category-count">(<%= tools.length %> tools)</span>
        </div>
        
        <% tools.each do |tool| %>
          <div class="tool">
            <div class="tool-name"><%= tool[:name] %></div>
            <div class="tool-description"><%= tool[:description] %></div>
            
            <% if tool[:inputSchema] && tool[:inputSchema][:properties] %>
              <div class="tool-inputs">
                <h4>Input Parameters:</h4>
                <% tool[:inputSchema][:properties].each do |param_name, param_details| %>
                  <div class="input-param">
                    <span class="param-name"><%= param_name %></span>
                    <span class="param-type">(<%= param_details[:type] %>)</span>
                    <% if tool[:inputSchema][:required]&.include?(param_name.to_s) %>
                      <span class="param-required">required</span>
                    <% end %>
                    <% if param_details[:description] %>
                      <br><span class="param-description"><%= param_details[:description] %></span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </body>
</html>